# .gitignore for tacotron2-wavernn project
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Virtual environment
.venv/
venv/
ENV/

# Parquet data files
*.parquet

# OS files
.DS_Store
Thumbs.db

# Shell history
.python_history

# VS Code settings
.vscode/

# Logs
*.log

# Ignore model checkpoints and outputs
checkpoints/
outputs/

# WaveRNN training notebook outputs (loss plot + epoch WAVs)
wavernn/training_monitor/

# Ignore any temp or cache files
*.tmp
*.cache
.cache/
.env

# Ignore test outputs
*.out
*.test

# Ignore large data files
*.h5
*.pth
*.pt
*.ckpt

clartts/

tacotron2-wavernn/
tacotron2-wavernn.zip

epoch_0096.zip

checkpoints.zip
loss_curve_wavernn.png


checkpoints_taco2/
annotated_dataset_omani/
dataset_new_omani/
